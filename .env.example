# ─────────────────────────────────────────────────────────
#  job-ai-agent — Environment Variables
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────

# Anthropic Claude API key
# Get it from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Gmail address the bot uses to send applications
GMAIL_ADDRESS=your.email@gmail.com

# Gmail App Password (NOT your real password)
# Steps to get it:
#   1. Go to myaccount.google.com/security
#   2. Enable 2-Step Verification
#   3. Go to myaccount.google.com/apppasswords
#   4. Select Mail > Windows Computer > Generate
#   5. Paste the 16-character code below
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Path to your CV PDF (place it in assets/ folder)
CV_PATH=./assets/Jasper_John_Paitan_CV.pdf
